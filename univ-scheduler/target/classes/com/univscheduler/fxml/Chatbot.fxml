<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.univscheduler.controller.ChatbotController"
            prefWidth="400" prefHeight="540"
            styleClass="chatbot-root">

    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Header draggable -->
        <HBox styleClass="chatbot-header" alignment="CENTER_LEFT" spacing="10"
              onMousePressed="#handleHeaderPressed"
              onMouseDragged="#handleHeaderDragged">
            <StackPane>
                <Circle radius="18" styleClass="avatar-circle"/>
                <FontIcon iconLiteral="fas-robot" iconSize="18" iconColor="white"/>
            </StackPane>
            <VBox spacing="1" HBox.hgrow="ALWAYS">
                <Label text="Assistant UNIV-SCHEDULER" styleClass="chatbot-title"/>
                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Circle radius="4" styleClass="status-dot"/>
                    <Label text="En ligne" styleClass="chatbot-status"/>
                </HBox>
            </VBox>
            <Button styleClass="chatbot-close" onAction="#handleClose">
                <graphic>
                    <FontIcon iconLiteral="fas-times" iconSize="13" iconColor="white"/>
                </graphic>
            </Button>
        </HBox>

        <!-- Zone messages scrollable -->
        <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS"
                    fitToWidth="true" styleClass="chatbot-scroll"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox fx:id="messagesBox" spacing="12"
                  style="-fx-padding: 16 14;" fillWidth="true"/>
        </ScrollPane>

        <!-- Suggestions rapides — texte et icônes configurés dynamiquement par initUser() -->
        <HBox fx:id="suggestionsBox" styleClass="chatbot-suggestions"
              spacing="6" alignment="CENTER_LEFT">
            <Button fx:id="btn1" styleClass="btn-suggest" onAction="#suggest1" text="..."/>
            <Button fx:id="btn2" styleClass="btn-suggest" onAction="#suggest2" text="..."/>
            <Button fx:id="btn3" styleClass="btn-suggest" onAction="#suggest3" text="..."/>
        </HBox>

        <!-- Barre de saisie -->
        <HBox styleClass="chatbot-input-bar" spacing="8" alignment="CENTER">
            <TextField fx:id="inputField"
                       promptText="Écrivez votre message..."
                       styleClass="chatbot-input"
                       HBox.hgrow="ALWAYS"
                       onAction="#handleSend"/>
            <Button styleClass="chatbot-send" onAction="#handleSend">
                <graphic>
                    <FontIcon iconLiteral="fas-paper-plane" iconSize="14" iconColor="white"/>
                </graphic>
            </Button>
        </HBox>

    </VBox>
</AnchorPane>
