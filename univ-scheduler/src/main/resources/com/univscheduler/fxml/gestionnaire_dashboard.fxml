<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.univscheduler.controller.GestionnaireDashboardController"
            styleClass="root-pane">
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16">
            <FontIcon iconLiteral="fas-graduation-cap" iconSize="22" iconColor="#a8d8e2"/>
            <Label text="UNIV-SCHEDULER" styleClass="nav-logo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Gestionnaire" styleClass="nav-role-badge-green"/>
            <Label fx:id="welcomeLabel" text="Bienvenue" styleClass="nav-user"/>
            <StackPane>
                <Button onAction="#handleVoirNotifications"
                        style="-fx-background-color:rgba(255,255,255,0.12);-fx-padding:5 12;
                               -fx-background-radius:10;-fx-cursor:hand;
                               -fx-border-color:rgba(255,255,255,0.20);-fx-border-radius:10;-fx-border-width:1;">
                    <graphic><FontIcon iconLiteral="fas-bell" iconSize="15" iconColor="#a8d8e2"/></graphic>
                </Button>
                <Label fx:id="notifBadge" text="0" visible="false"
                       StackPane.alignment="TOP_RIGHT" translateX="6" translateY="-6"
                       style="-fx-background-color:#e05c5c;-fx-text-fill:white;-fx-font-size:9px;
                              -fx-font-weight:bold;-fx-background-radius:10;-fx-padding:1 5;
                              -fx-min-width:18;-fx-alignment:CENTER;"/>
            </StackPane>
            <Button onAction="#openChatbot"
                    style="-fx-background-color:#2a9cb0;-fx-text-fill:white;-fx-font-weight:bold;
                           -fx-padding:6 14;-fx-background-radius:10;-fx-cursor:hand;-fx-font-size:12px;">
                <graphic><FontIcon iconLiteral="fas-robot" iconSize="13" iconColor="white"/></graphic>
                <text>Assistant</text>
            </Button>
            <Button styleClass="btn-logout" onAction="#handleLogout">
                <graphic><FontIcon iconLiteral="fas-sign-out-alt" iconSize="13" iconColor="white"/></graphic>
                <text>Deconnexion</text>
            </Button>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="16" style="-fx-padding:20;">
                <HBox spacing="12">
                    <VBox styleClass="stat-card stat-teal" HBox.hgrow="ALWAYS" spacing="4">
                        <Label text="TOTAL COURS" styleClass="stat-label"/>
                        <Label fx:id="totalCoursLabel" text="0" styleClass="stat-value-small"/>
                    </VBox>
                    <VBox styleClass="stat-card stat-orange" HBox.hgrow="ALWAYS" spacing="4">
                        <Label text="CONFLITS" styleClass="stat-label"/>
                        <Label fx:id="conflitsLabel" text="0" styleClass="stat-value-small"/>
                    </VBox>
                </HBox>
                <TabPane>
                    <!-- Tab 1 : Emploi du Temps -->
                    <Tab closable="false">
                        <graphic><HBox spacing="5" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-list-alt" iconSize="13" iconColor="#2a9cb0"/><Label text="Emploi du Temps"/></HBox></graphic>
                        <HBox spacing="16">
                            <VBox HBox.hgrow="ALWAYS" spacing="8">
                                <Label text="Tous les Cours" styleClass="section-title"/>
                                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color:white;-fx-padding:8 12;-fx-background-radius:10;-fx-border-color:#d4ecf0;-fx-border-radius:10;-fx-border-width:1;">
                                    <FontIcon iconLiteral="fas-graduation-cap" iconSize="12" iconColor="#4a7a87"/>
                                    <Label text="Classe :" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#4a7a87;"/>
                                    <ComboBox fx:id="filtreClasseCombo" prefWidth="200" promptText="Toutes les classes" style="-fx-font-size:12px;"/>
                                    <Button onAction="#handleReinitialiseFiltreClasse" style="-fx-background-color:#e0f0f4;-fx-text-fill:#2a6a7a;-fx-font-size:11px;-fx-font-weight:bold;-fx-padding:5 10;-fx-background-radius:8;-fx-cursor:hand;">
                                        <graphic><FontIcon iconLiteral="fas-times" iconSize="10" iconColor="#2a6a7a"/></graphic>
                                    </Button>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="filtreInfoLabel" text="" style="-fx-font-size:11px;-fx-text-fill:#2a9cb0;-fx-font-style:italic;"/>
                                </HBox>
                                <TableView fx:id="coursTable" prefHeight="460" styleClass="data-table">
                                    <columns>
                                        <TableColumn fx:id="colMat"    text="Matiere"    prefWidth="140"/>
                                        <TableColumn fx:id="colEns"    text="Enseignant" prefWidth="130"/>
                                        <TableColumn fx:id="colCls"    text="Classe"     prefWidth="100"/>
                                        <TableColumn fx:id="colCren"   text="Creneau"    prefWidth="110"/>
                                        <TableColumn fx:id="colSalle"  text="Salle"      prefWidth="70"/>
                                        <TableColumn fx:id="colDate"   text="Date"       prefWidth="90"/>
                                        <TableColumn fx:id="colStatut" text="Statut"     prefWidth="90"/>
                                    </columns>
                                    <placeholder><Label text="Aucun cours pour cette classe." style="-fx-text-fill:#9eb3bf;-fx-font-style:italic;"/></placeholder>
                                </TableView>
                                <HBox spacing="8">
                                    <Button styleClass="btn-secondary" onAction="#handleExportPDF">
                                        <graphic><FontIcon iconLiteral="fas-file-pdf" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                        <text>Export PDF</text>
                                    </Button>
                                    <Button styleClass="btn-secondary" onAction="#handleExportExcel">
                                        <graphic><FontIcon iconLiteral="fas-file-excel" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                        <text>Export Excel</text>
                                    </Button>
                                </HBox>
                            </VBox>
                            <VBox styleClass="form-panel" spacing="10" minWidth="290" maxWidth="290">
                                <Label fx:id="coursFormTitle" text="Nouveau Cours" styleClass="form-title"/>
                                <Label fx:id="conflitLabel" text="" wrapText="true" maxWidth="270"/>
                                <Label text="Matiere"    styleClass="form-label"/>
                                <ComboBox fx:id="matiereCombo"    maxWidth="Infinity"/>
                                <Label text="Enseignant" styleClass="form-label"/>
                                <ComboBox fx:id="enseignantCombo" maxWidth="Infinity"/>
                                <Label text="Classe"     styleClass="form-label"/>
                                <ComboBox fx:id="classeCombo"     maxWidth="Infinity"/>
                                <Label text="Creneau"    styleClass="form-label"/>
                                <ComboBox fx:id="creneauCombo"    maxWidth="Infinity"/>
                                <Label text="Date"       styleClass="form-label"/>
                                <DatePicker fx:id="datePicker"    maxWidth="Infinity"/>
                                <Label text="Salle"      styleClass="form-label"/>
                                <ComboBox fx:id="salleCombo"      maxWidth="Infinity"/>
                                <Label fx:id="salleAutoLabel" text="" wrapText="true" visible="false" maxWidth="Infinity" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-padding:6 10;-fx-background-radius:8;"/>
                                <Label text="Statut"     styleClass="form-label"/>
                                <ComboBox fx:id="statutCombo"     maxWidth="Infinity"/>
                                <Button styleClass="btn-primary" onAction="#handleSaveCours" maxWidth="Infinity">
                                    <graphic><FontIcon iconLiteral="fas-save" iconSize="13" iconColor="white"/></graphic>
                                    <text>Sauvegarder</text>
                                </Button>
                                <HBox spacing="6">
                                    <Button styleClass="btn-danger" onAction="#handleDeleteCours" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                        <graphic><FontIcon iconLiteral="fas-trash" iconSize="12" iconColor="white"/></graphic>
                                        <text>Supprimer</text>
                                    </Button>
                                    <Button styleClass="btn-secondary" onAction="#handleClearCours" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                        <graphic><FontIcon iconLiteral="fas-times" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                        <text>Annuler</text>
                                    </Button>
                                </HBox>
                            </VBox>
                        </HBox>
                    </Tab>
                    <!-- Tab 2 : Calendrier -->
                    <Tab closable="false">
                        <graphic><HBox spacing="5" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-calendar-alt" iconSize="13" iconColor="#2a9cb0"/><Label text="Vue Calendrier"/></HBox></graphic>
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:8 12;-fx-background-color:white;-fx-background-radius:14;">
                                <Button styleClass="btn-secondary" onAction="#handlePrevWeek">
                                    <graphic><FontIcon iconLiteral="fas-chevron-left" iconSize="11" iconColor="#1a5f6e"/></graphic>
                                    <text>Prec.</text>
                                </Button>
                                <Label fx:id="calendarWeekLabel" text="Semaine courante" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                                <Button styleClass="btn-secondary" onAction="#handleTodayWeek">
                                    <graphic><FontIcon iconLiteral="fas-calendar-check" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                    <text>Aujourd'hui</text>
                                </Button>
                                <Button styleClass="btn-secondary" onAction="#handleNextWeek">
                                    <text>Suiv.</text>
                                    <graphic><FontIcon iconLiteral="fas-chevron-right" iconSize="11" iconColor="#1a5f6e"/></graphic>
                                </Button>
                                <Separator orientation="VERTICAL"/>
                                <Button fx:id="btnVueSemaine" onAction="#handleVueSemaine" style="-fx-background-color:#1a5f6e;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:6 14;-fx-background-radius:10;-fx-cursor:hand;">
                                    <graphic><FontIcon iconLiteral="fas-th" iconSize="12" iconColor="white"/></graphic>
                                    <text>Semaine</text>
                                </Button>
                                <Button fx:id="btnVueMois" onAction="#handleVueMois" style="-fx-background-color:#e0f0f4;-fx-text-fill:#1a5f6e;-fx-font-weight:bold;-fx-padding:6 14;-fx-background-radius:10;-fx-cursor:hand;">
                                    <graphic><FontIcon iconLiteral="fas-calendar" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                    <text>Mois</text>
                                </Button>
                            </HBox>
                            <ScrollPane fitToWidth="true" fitToHeight="false" prefHeight="540">
                                <GridPane fx:id="calendarGrid" hgap="0" vgap="0" style="-fx-background-color:#d4ecf0;"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>
                    <!-- Tab 3 : Reservations -->
                    <Tab closable="false">
                        <graphic><HBox spacing="5" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-bookmark" iconSize="13" iconColor="#2a9cb0"/><Label text="Reservations"/></HBox></graphic>
                        <VBox spacing="10">
                            <Label text="Demandes en Attente de Validation" styleClass="section-title"/>
                            <TableView fx:id="reservTable" prefHeight="380" styleClass="data-table">
                                <columns>
                                    <TableColumn fx:id="colResUser"   text="Demandeur" prefWidth="150"/>
                                    <TableColumn fx:id="colResMotif"  text="Motif"     prefWidth="200"/>
                                    <TableColumn fx:id="colResSalle"  text="Salle"     prefWidth="80"/>
                                    <TableColumn fx:id="colResDate"   text="Date"      prefWidth="100"/>
                                    <TableColumn fx:id="colResStatut" text="Statut"    prefWidth="110"/>
                                </columns>
                            </TableView>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Button onAction="#handleValiderReserv" style="-fx-background-color:#3ecf8e;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 20;-fx-background-radius:10;-fx-cursor:hand;">
                                    <graphic><FontIcon iconLiteral="fas-check-circle" iconSize="14" iconColor="white"/></graphic>
                                    <text>Valider</text>
                                </Button>
                                <Button onAction="#handleRefuserReserv" style="-fx-background-color:#e05c5c;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 20;-fx-background-radius:10;-fx-cursor:hand;">
                                    <graphic><FontIcon iconLiteral="fas-times-circle" iconSize="14" iconColor="white"/></graphic>
                                    <text>Refuser</text>
                                </Button>
                            </HBox>
                        </VBox>
                    </Tab>
                    <!-- Tab 4 : Historique -->
                    <Tab closable="false">
                        <graphic><HBox spacing="5" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-history" iconSize="13" iconColor="#2a9cb0"/><Label text="Historique"/></HBox></graphic>
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Historique Complet des Reservations" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                                <Button styleClass="btn-secondary" onAction="#handleExportHistoriquePDF">
                                    <graphic><FontIcon iconLiteral="fas-file-pdf" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                    <text>Export PDF</text>
                                </Button>
                                <Button styleClass="btn-secondary" onAction="#handleExportHistoriqueExcel">
                                    <graphic><FontIcon iconLiteral="fas-file-excel" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                    <text>Export Excel</text>
                                </Button>
                            </HBox>
                            <TableView fx:id="historiqueTable" prefHeight="460" styleClass="data-table">
                                <columns>
                                    <TableColumn fx:id="colHistUser"   text="Demandeur" prefWidth="150"/>
                                    <TableColumn fx:id="colHistMotif"  text="Motif"     prefWidth="200"/>
                                    <TableColumn fx:id="colHistSalle"  text="Salle"     prefWidth="80"/>
                                    <TableColumn fx:id="colHistDate"   text="Date"      prefWidth="120"/>
                                    <TableColumn fx:id="colHistStatut" text="Statut"    prefWidth="120"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </Tab>
                    <!-- Tab 5 : Carte Salles -->
                    <Tab closable="false">
                        <graphic><HBox spacing="5" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-map-marked-alt" iconSize="13" iconColor="#2a9cb0"/><Label text="Carte Salles"/></HBox></graphic>
                        <VBox spacing="12">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Carte Interactive des Salles" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                                <Button styleClass="btn-secondary" onAction="#handleRafraichirCarte">
                                    <graphic><FontIcon iconLiteral="fas-sync-alt" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                    <text>Rafraichir</text>
                                </Button>
                                <Button styleClass="btn-secondary" onAction="#handleExportOccupationExcel">
                                    <graphic><FontIcon iconLiteral="fas-file-excel" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                    <text>Export Occupation Excel</text>
                                </Button>
                            </HBox>
                            <ScrollPane fitToWidth="true" fitToHeight="false" prefHeight="620">
                                <VBox fx:id="carteContainer" spacing="12" style="-fx-padding:8;"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>
                    <!-- Tab 6 : Rapports -->
                    <Tab closable="false">
                        <graphic><HBox spacing="5" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-chart-line" iconSize="13" iconColor="#2a9cb0"/><Label text="Rapports"/></HBox></graphic>
                        <VBox spacing="16" style="-fx-padding:12;">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button styleClass="btn-primary" onAction="#handleRapportHebdo">
                                    <graphic><FontIcon iconLiteral="fas-calendar-week" iconSize="13" iconColor="white"/></graphic>
                                    <text>Rapport Hebdomadaire</text>
                                </Button>
                                <Button styleClass="btn-secondary" onAction="#handleRapportMensuel">
                                    <graphic><FontIcon iconLiteral="fas-calendar-alt" iconSize="13" iconColor="#1a5f6e"/></graphic>
                                    <text>Rapport Mensuel</text>
                                </Button>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button styleClass="btn-secondary" onAction="#handleRefreshRapport">
                                    <graphic><FontIcon iconLiteral="fas-sync-alt" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                    <text>Actualiser</text>
                                </Button>
                            </HBox>
                            <GridPane hgap="14" vgap="14">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints minHeight="320"/>
                                    <RowConstraints minHeight="320"/>
                                </rowConstraints>
                                <VBox fx:id="rapportGaugeContainer"  styleClass="form-panel" spacing="0" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <VBox fx:id="rapportSupplyContainer" styleClass="form-panel" spacing="0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <VBox fx:id="rapportTrendContainer"  styleClass="form-panel" spacing="0" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <VBox fx:id="rapportHealthContainer" styleClass="form-panel" spacing="0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            </GridPane>
                            <HBox spacing="14">
                                <VBox styleClass="form-panel" HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Taux d'Occupation par Salle" styleClass="form-title"/>
                                    <VBox fx:id="chartOccupationContainer" minHeight="260"/>
                                </VBox>
                                <VBox styleClass="form-panel" minWidth="290" maxWidth="290" spacing="6">
                                    <Label text="Salles Critiques (>=70%)" styleClass="form-title"/>
                                    <TableView fx:id="sallesCritiquesTable" prefHeight="230" styleClass="data-table">
                                        <columns>
                                            <TableColumn fx:id="colCritNum"  text="Salle"      prefWidth="80"/>
                                            <TableColumn fx:id="colCritType" text="Type"       prefWidth="55"/>
                                            <TableColumn fx:id="colCritCap"  text="Cap."       prefWidth="50"/>
                                            <TableColumn fx:id="colCritTaux" text="Occupation" prefWidth="100"/>
                                        </columns>
                                    </TableView>
                                </VBox>
                            </HBox>
                            <HBox spacing="14">
                                <VBox styleClass="form-panel" HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Cours par Jour" styleClass="form-title"/>
                                    <VBox fx:id="chartCoursContainer" minHeight="220"/>
                                </VBox>
                                <VBox styleClass="form-panel" HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Statut des Cours" styleClass="form-title"/>
                                    <VBox fx:id="chartReservContainer" minHeight="220"/>
                                </VBox>
                            </HBox>
                            <VBox styleClass="form-panel" spacing="4">
                                <Label text="Rapport Textuel" styleClass="form-title"/>
                                <TextArea fx:id="rapportTextArea" prefHeight="160" editable="false" style="-fx-font-family:monospace;-fx-font-size:11px;" promptText="Cliquez sur 'Rapport Hebdomadaire' ou 'Rapport Mensuel'..."/>
                            </VBox>
                        </VBox>
                    </Tab>
                    <!-- Tab 7 : Signalements -->
                    <Tab closable="false">
                        <graphic><HBox spacing="5" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-exclamation-triangle" iconSize="13" iconColor="#f0a500"/><Label text="Signalements"/></HBox></graphic>
                        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;">
                            <VBox spacing="16" style="-fx-padding:16;">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-tools" iconSize="18" iconColor="#1a5f6e"/>
                                    <Label text="Signalements des Enseignants" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a5f6e;"/>
                                    <Label fx:id="signalBadge" text="" visible="false" style="-fx-background-color:#fee2e2;-fx-text-fill:#991b1b;-fx-font-size:12px;-fx-font-weight:bold;-fx-padding:3 12;-fx-background-radius:20;"/>
                                </HBox>
                                <VBox spacing="10" styleClass="form-panel">
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <Label text="Liste des signalements recus" styleClass="form-title" HBox.hgrow="ALWAYS"/>
                                        <Button styleClass="btn-secondary" onAction="#handleVoirDetailSignal">
                                            <graphic><FontIcon iconLiteral="fas-search" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                            <text>Voir detail</text>
                                        </Button>
                                        <Button styleClass="btn-secondary" onAction="#handleRefresh">
                                            <graphic><FontIcon iconLiteral="fas-sync-alt" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                            <text>Actualiser</text>
                                        </Button>
                                    </HBox>
                                    <TableView fx:id="signalTable" prefHeight="300" styleClass="data-table">
                                        <columns>
                                            <TableColumn fx:id="colSignTitre"  text="Titre"      prefWidth="200"/>
                                            <TableColumn fx:id="colSignEns"    text="Enseignant" prefWidth="140"/>
                                            <TableColumn fx:id="colSignSalle"  text="Salle"      prefWidth="80"/>
                                            <TableColumn fx:id="colSignCat"    text="Categorie"  prefWidth="110"/>
                                            <TableColumn fx:id="colSignPrio"   text="Priorite"   prefWidth="110"/>
                                            <TableColumn fx:id="colSignStatut" text="Statut"     prefWidth="130"/>
                                            <TableColumn fx:id="colSignDate"   text="Date"       prefWidth="100"/>
                                        </columns>
                                        <placeholder><Label text="Aucun signalement recu." style="-fx-text-fill:#9eb3bf;-fx-font-style:italic;"/></placeholder>
                                    </TableView>
                                </VBox>
                                <VBox spacing="12" styleClass="form-panel">
                                    <Label text="Traiter le signalement selectionne" styleClass="form-title"/>
                                    <VBox spacing="4">
                                        <Label text="Nouveau statut" styleClass="form-label"/>
                                        <ComboBox fx:id="signalStatutCombo" maxWidth="Infinity" promptText="Choisir un statut..."/>
                                    </VBox>
                                    <VBox spacing="4">
                                        <Label text="Commentaire / Reponse (optionnel)" styleClass="form-label"/>
                                        <TextArea fx:id="signalCommentArea" promptText="Ex: Probleme pris en charge, technicien prevu le 20/03..." prefRowCount="3" wrapText="true"/>
                                    </VBox>
                                    <HBox alignment="CENTER_RIGHT" spacing="12">
                                        <Button styleClass="btn-secondary" onAction="#handleVoirDetailSignal">
                                            <graphic><FontIcon iconLiteral="fas-search" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                            <text>Voir detail complet</text>
                                        </Button>
                                        <Button styleClass="btn-primary" onAction="#handleTraiterSignalement" style="-fx-padding:10 24;">
                                            <graphic><FontIcon iconLiteral="fas-check-circle" iconSize="13" iconColor="white"/></graphic>
                                            <text>Valider le traitement</text>
                                        </Button>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </ScrollPane>
                    </Tab>
                    <!-- Tab 8 : Examens & Devoirs -->
                    <Tab closable="false">
                        <graphic><HBox spacing="5" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-edit" iconSize="13" iconColor="#2a9cb0"/><Label text="Examens et Devoirs"/></HBox></graphic>
                        <VBox spacing="14" style="-fx-padding:16;">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Demandes d'Examens et Devoirs" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1a5f6e;" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="examenBadge" text="" visible="false" style="-fx-background-color:#fee2e2;-fx-text-fill:#991b1b;-fx-font-size:12px;-fx-font-weight:bold;-fx-padding:3 12;-fx-background-radius:20;"/>
                                <Button styleClass="btn-secondary" onAction="#handleRefreshExamens">
                                    <graphic><FontIcon iconLiteral="fas-sync-alt" iconSize="12" iconColor="#1a5f6e"/></graphic>
                                    <text>Actualiser</text>
                                </Button>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color:white;-fx-padding:8 12;-fx-background-radius:10;-fx-border-color:#d4ecf0;-fx-border-radius:10;-fx-border-width:1;">
                                <Label text="Filtrer :" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#4a7a87;"/>
                                <ComboBox fx:id="examenFiltreCombo" prefWidth="180" onAction="#handleFiltreExamens"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="examenInfoLabel" text="" style="-fx-font-size:11px;-fx-text-fill:#2a9cb0;-fx-font-style:italic;"/>
                            </HBox>
                            <TableView fx:id="examenTable" prefHeight="380" styleClass="data-table">
                                <columns>
                                    <TableColumn fx:id="colExType"    text="Type"       prefWidth="90"/>
                                    <TableColumn fx:id="colExEns"     text="Enseignant" prefWidth="140"/>
                                    <TableColumn fx:id="colExTitre"   text="Titre"      prefWidth="160"/>
                                    <TableColumn fx:id="colExClasse"  text="Classe"     prefWidth="110"/>
                                    <TableColumn fx:id="colExMatiere" text="Matiere"    prefWidth="130"/>
                                    <TableColumn fx:id="colExDate"    text="Date"       prefWidth="130"/>
                                    <TableColumn fx:id="colExSalle"   text="Salle"      prefWidth="80"/>
                                    <TableColumn fx:id="colExStatut"  text="Statut"     prefWidth="115"/>
                                </columns>
                                <placeholder><Label text="Aucune demande." style="-fx-text-fill:#9eb3bf;-fx-font-style:italic;"/></placeholder>
                            </TableView>
                            <VBox styleClass="form-panel" spacing="12">
                                <Label text="Traiter la demande selectionnee" styleClass="form-title"/>
                                <VBox spacing="5">
                                    <Label text="Commentaire / Motif (optionnel)" styleClass="form-label"/>
                                    <TextField fx:id="examenMotifField" promptText="Ex: Salle confirmee, creneau approuve..." styleClass="form-field"/>
                                </VBox>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Button onAction="#handleValiderExamen" style="-fx-background-color:#3ecf8e;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:10 24;-fx-background-radius:10;-fx-cursor:hand;">
                                        <graphic><FontIcon iconLiteral="fas-check-circle" iconSize="14" iconColor="white"/></graphic>
                                        <text>Valider la demande</text>
                                    </Button>
                                    <Button onAction="#handleRefuserExamen" style="-fx-background-color:#e05c5c;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:10 24;-fx-background-radius:10;-fx-cursor:hand;">
                                        <graphic><FontIcon iconLiteral="fas-times-circle" iconSize="14" iconColor="white"/></graphic>
                                        <text>Refuser la demande</text>
                                    </Button>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="examenActionFeedback" text="" visible="false" style="-fx-font-weight:bold;-fx-font-size:12px;"/>
                                </HBox>
                                <Label text="Si validee : l'enseignant recoit une notification + email de confirmation." style="-fx-text-fill:#64748b;-fx-font-size:10px;" wrapText="true"/>
                            </VBox>
                        </VBox>
                    </Tab>
                </TabPane>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>